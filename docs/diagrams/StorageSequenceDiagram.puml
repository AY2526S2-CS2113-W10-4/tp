@startuml
actor User
participant ":GoldenCompass" as GC
participant ":InternshipStorage" as InternStorage
participant ":InterviewStorage" as InterviewStorage
participant ":AliasStorage" as AliasStorage

activate GC
loop while application is running
    User -> GC : inputs command (e.g., "add", "mark")

    note right of GC : Command executes, then\ntriggers eager saving

    GC -> InternStorage : save(internshipList)
    activate InternStorage
    InternStorage -> InternStorage : Check/Create "data/" directory
    InternStorage -> InternStorage : Format and write internships
    InternStorage --> GC
    deactivate InternStorage

    GC -> InterviewStorage : save(interviewList)
    activate InterviewStorage
    InterviewStorage -> InterviewStorage : Check/Create "data/" directory
    InterviewStorage -> InterviewStorage : Format and write interviews\n(Links Company & Role)
    InterviewStorage --> GC
    deactivate InternStorage

    GC -> AliasStorage : save(aliasMap)
    activate AliasStorage
    AliasStorage -> AliasStorage : Check/Create "data/" directory
    AliasStorage -> AliasStorage : Format and write custom aliases
    AliasStorage --> GC
    deactivate AliasStorage

    GC --> User : prints command result
end
deactivate GC
@enduml